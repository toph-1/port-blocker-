sudo tee /usr/local/bin/portblock << 'EOF'
#!/bin/bash
while true; do
clear
echo "=========================="
echo "  PORT BLOCKING TOOL"
echo "=========================="
echo "1) BLOCK all outside"
echo "2) OPEN all connections"
echo "3) Block specific port"
echo "4) Unblock specific port"
echo "5) Show status"
echo "6) Save rules"
echo "7) Complete reset"
echo "8) Exit"
echo "=========================="
read -p "Choose (1-8): " c

case $c in
1)
  echo "Blocking outside connections..."
  sudo iptables -P INPUT DROP
  sudo iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
  sudo iptables -A INPUT -i lo -j ACCEPT
  echo "DONE! Outside blocked"
  sleep 2
  ;;
2)
  echo "Opening all connections..."
  sudo iptables -P INPUT ACCEPT
  sudo iptables -F INPUT
  echo "DONE! All open"
  sleep 2
  ;;
3)
  read -p "Port number to block: " p
  sudo iptables -A INPUT -p tcp --dport $p -j DROP
  sudo iptables -A INPUT -p udp --dport $p -j DROP
  echo "Port $p blocked"
  sleep 2
  ;;
4)
  read -p "Port number to unblock: " p
  sudo iptables -D INPUT -p tcp --dport $p -j DROP 2>/dev/null
  sudo iptables -D INPUT -p udp --dport $p -j DROP 2>/dev/null
  echo "Port $p unblocked"
  sleep 2
  ;;
5)
  clear
  echo "--- CURRENT STATUS ---"
  sudo iptables -L INPUT | head -1
  echo ""
  echo "--- BLOCKED PORTS ---"
  sudo iptables -L INPUT -n | grep DROP
  read -p "Press Enter"
  ;;
6)
  sudo apt-get install -y iptables-persistent
  sudo netfilter-persistent save
  echo "Rules saved!"
  sleep 2
  ;;
7)
  read -p "Type YES to reset all: " confirm
  if [ "$confirm" = "YES" ]; then
    sudo iptables -P INPUT ACCEPT
    sudo iptables -F
    echo "Complete reset done!"
  fi
  sleep 2
  ;;
8)
  echo "Goodbye!"
  exit 0
  ;;
*)
  echo "Invalid choice"
  sleep 1
  ;;
esac
done
EOF

sudo chmod +x /usr/local/bin/portblock
echo "Installation done! Type: portblock"
